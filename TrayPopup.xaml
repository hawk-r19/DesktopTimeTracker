<UserControl x:Class="DesktopTimeTracker.TrayPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200">

    <UserControl.Resources>
        <!-- Rounded Button Style -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505055"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#606065"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" 
            CornerRadius="5" Padding="10">
        <StackPanel>
            <!-- Timer Display -->
            <TextBlock x:Name="TimerDisplay" 
                       Text="00:00:00" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#E0E0E0"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            
            <!-- Status Text -->
            <TextBlock x:Name="StatusText"
                       Text="Off Task"
                       FontSize="12"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>
            
            <!-- Buttons -->
            <Button Content="Reset" 
                    Click="Reset_Click"
                    Margin="0,0,0,5"
                    Style="{StaticResource RoundedButton}"/>
            
            <Button Name="PauseButton"
                    Content="Pause" 
                    Click="Pause_Click"
                    Margin="0,0,0,5"
                    Padding="10,5"
                    Style="{StaticResource RoundedButton}"/>
            
            <Button Content="Open Window" 
                    Click="OpenWindow_Click"
                    Padding="10,5"
                    Style="{StaticResource RoundedButton}"/>
        </StackPanel>
    </Border>
</UserControl>