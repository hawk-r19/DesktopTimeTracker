<UserControl x:Class="DesktopTimeTracker.TrayPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200">
    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" 
            CornerRadius="5" Padding="10">
        <StackPanel>
            <!-- Timer Display -->
            <TextBlock x:Name="TimerDisplay" 
                       Text="00:00:00" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#E0E0E0"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            
            <!-- Status Text -->
            <TextBlock x:Name="StatusText"
                       Text="Off Task"
                       FontSize="12"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>
            
            <!-- Buttons -->
            <Button Content="Reset" 
                    Click="Reset_Click"
                    Margin="0,0,0,5"
                    Padding="10,5"
                    Background="#3E3E42"
                    Foreground="#E0E0E0"
                    BorderBrush="#555555"/>
            
            <Button Name="PauseButton"
                    Content="Pause" 
                    Click="Pause_Click"
                    Margin="0,0,0,5"
                    Padding="10,5"
                    Background="#3E3E42"
                    Foreground="#E0E0E0"
                    BorderBrush="#555555"/>
            
            <Button Content="Open Window" 
                    Click="OpenWindow_Click"
                    Padding="10,5"
                    Background="#3E3E42"
                    Foreground="#E0E0E0"
                    BorderBrush="#555555"/>
        </StackPanel>
    </Border>
</UserControl>