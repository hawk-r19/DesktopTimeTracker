<Window x:Class="DesktopTimeTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopTimeTracker"
        mc:Ignorable="d"
        Title="Desktop Time Tracker" Height="380" Width="370"
        Icon="/timer_icon.ico"
        Closing="WindowClosing"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <!--Background="#2D2D30" 
        BorderBrush="#3F3F46"
        BorderThickness="1"-->

    <Window.Resources>
        <!-- Rounded Button Style -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505055"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#606065"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#2D2D30" 
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="24">
        
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar for Dragging -->
            <Grid Grid.Row="0" 
                  Background="Transparent" 
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  VerticalAlignment="Top"
                  Cursor="Hand">
                <Button Content="—" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="30"
                        Height="25"
                        FontSize="20"
                        FontWeight="ExtraBold"
                        Margin="0 1 10 0"
                        Padding="2 -4 2 2"
                        Background="Transparent"
                        Foreground="#E0E0E0"
                        BorderThickness="0"
                        Click="CloseButton_Click"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Top"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#606065"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Main Content -->
            <StackPanel Grid.Row="1">

                <TextBlock
                    Text="Desktop Time Tracker"
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="#E0E0E0"
                    HorizontalAlignment="Center"
                    Margin="0 0 0 5"/>

                <TextBlock
                    x:Name="TimeLabel"
                    FontSize="38"
                    FontWeight="Bold"
                    Foreground="#E0E0E0"
                    HorizontalAlignment="Center"
                    Text="00:00:00"/>

                <!-- Status Text -->
                <TextBlock x:Name="StatusText"
                   Text="Off Task"
                   FontSize="18"
                   Foreground="#AAAAAA"
                   HorizontalAlignment="Center"
                   Margin="0,5,0,10"/>

                <!-- Active Desktop Selection -->
                <TextBlock Text="Active Desktops:" 
                           FontSize="16" 
                           Foreground="#E0E0E0" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center"
                           Margin="0 0 0 10"/>
                <ItemsControl ItemsSource="{Binding DesktopButtons}" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                Tag="{Binding Id}"
                                Click="Desktop_Click"
                                Padding="10,5"
                                FontSize="14"
                                Background="#3E3E42"
                                Foreground="#E0E0E0"
                                BorderBrush="{Binding statusColor}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Buttons -->
                <Button
                    Content="Pause Tracking"
                    Name="PauseButton"
                    Width="125"
                    Margin="0 10 0 0"
                    FontSize="14"
                    VerticalAlignment="Center"
                    Style="{StaticResource RoundedButton}"
                    Click="Pause_Click"/>

                <Button
                    Content="Reset"
                    Width="120"
                    Margin="0 10 0 0"
                    FontSize="14"
                    VerticalAlignment="Center"
                    Style="{StaticResource RoundedButton}"
                    Click="Reset_Click"/>

                <Button
                    Content="Exit"
                    Width="120"
                    Margin="0 10 0 0"
                    FontSize="14"
                    VerticalAlignment="Center"
                    Style="{StaticResource RoundedButton}"
                    Click="Exit_Click"/>

            </StackPanel>

        </Grid>
    </Border>
</Window>
