<Window x:Class="DesktopTimeTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopTimeTracker"
        mc:Ignorable="d"
        Title="Desktop Time Tracker" Height="450" Width="800"
        Icon="/timer_icon.ico">
    <Grid Margin="20">

        <StackPanel>

            <TextBlock
            Text="Project Time Tracker"
            FontSize="20"
            FontWeight="Bold"
            Margin="0 0 0 20"/>

            <TextBlock
            x:Name="TimeLabel"
            FontSize="28"
            Text="00:00:00"/>

            <Button
            Content="Reset Timer"
            Width="120"
            Margin="0 20 0 0"
            Click="ResetTimer"/>

        </StackPanel>

    </Grid>
</Window>
